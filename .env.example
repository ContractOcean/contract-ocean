# Contract Ocean — Environment Variables
# Copy this file to .env and fill in your values.

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase Service Role (SERVER-ONLY — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (SERVER-ONLY — never expose to client)
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=

# App URL (used for Stripe redirect URLs)
APP_URL=

# Stripe (CLIENT-SAFE — publishable key only)
# VITE_STRIPE_PUBLISHABLE_KEY=
